# Provider-neutral model gateway. Keep secrets in the runtime environment or a
# secret manager; never commit a real key to this file.
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.6-terra
LLM_MODELS=gpt-5.6-terra,gpt-5.6-luna,claude-sonnet-4-6
LLM_FALLBACK_PROVIDER=anthropic
LLM_FALLBACK_MODEL=claude-sonnet-4-6
LLM_REQUEST_TIMEOUT_SECONDS=120
ALITIGATOR_CHAT_REQUEST_DEADLINE_SECONDS=120
ALITIGATOR_HINTS_REQUEST_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=2
LEGAL_PLANNER_MODEL=gpt-5.6-terra
EVIDENCE_ANALYST_MODEL=gpt-5.6-terra
AUTHORITY_EXTRACTOR_MODEL=gpt-5.6-terra
LEGAL_SYNTHESIS_MODEL=gpt-5.6-terra
ANSWER_WRITER_MODEL=gpt-5.6-terra
LEGAL_HINTS_MODEL=gpt-5.6-terra

# Reversible request routing: legacy, model_rag_model, shadow.
LEGAL_RAG_MODE=legacy
LEGAL_PIPELINE_MODE=legacy
LEGAL_ALLOW_LEGACY_FALLBACK=true
LEGAL_PLANNER_CONFIDENCE_THRESHOLD=0.55
LEGAL_MAX_RETRIEVAL_ITERATIONS=2
MODEL_RAG_MODEL_ARTIFACT_ROOT=artifacts/model_rag_model
# Compatibility aliases used by the first additive v2 implementation.
LEGAL_RAG_V2_ALLOW_LEGACY_FALLBACK=true
LEGAL_RAG_V2_EMERGENCY_DOCUMENT_FALLBACK=false
LEGAL_RAG_V2_PLANNER_CONFIDENCE_THRESHOLD=0.55
LEGAL_RAG_V2_ARTIFACT_ROOT=artifacts/model_rag_model
LEGAL_RAG_V2_SHADOW_MAX_CONCURRENCY=2

# Real embeddings are the v2 default. Hash embeddings require the explicit
# offline fallback flag and are never selected merely because retrieval misses.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_SCHEMA_VERSION=v1
EMBEDDING_CHUNKER_VERSION=provision_units_v1
EMBEDDING_INDEX_PATH=artifacts/model_rag_model/embedding_index.sqlite3
LEGAL_RAG_V2_ALLOW_OFFLINE_HASH_EMBEDDINGS=false

# Anthropic remains an optional technical fallback provider.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODELS=claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5-20251001
ANTHROPIC_HINTS_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_CHAT_MAX_TOKENS=6000
# Dlugie odpowiedzi sa akceptowalne; backend nie powinien ich ucinać zbyt wcześnie.
ANTHROPIC_CHAT_TIMEOUT_SECONDS=240
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWKS_URL=
ALITIGATOR_ADMIN_EMAILS=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
## For local development with Stripe CLI prefer a test key, not sk_live.
ALITIGATOR_STRIPE_SUCCESS_URL=http://localhost:5173?checkout=success
ALITIGATOR_STRIPE_CANCEL_URL=http://localhost:5173?checkout=cancel
ALITIGATOR_CREDIT_PACKS_JSON=[{"id":"solo-1","name":"1 kredyt","credit_amount":1,"price_gross":200,"currency":"pln","description":"1 kredyt do wykorzystania w aplikacji."},{"id":"mini-5","name":"5 kredytow","credit_amount":5,"price_gross":1000,"currency":"pln","description":"5 kredytow do wykorzystania w aplikacji."},{"id":"pro-20","name":"20 kredytow","credit_amount":20,"price_gross":4000,"currency":"pln","description":"20 kredytow do wykorzystania w aplikacji."}]
ALITIGATOR_CREDIT_COST_PER_QUERY=1
ALITIGATOR_CREDIT_UNIT_PRICE_GROSS=200
ALITIGATOR_CREDIT_CURRENCY=pln
ALITIGATOR_RAG_SOURCE_PATH=
# Comma-separated JSONL sources additionally indexed with the EUREKA corpus.
# Each record must declare source_type: interpretation, statute, judgment, or commentary.
# By default, existing statute JSONL files and data/processed/cbosa_nsa_fsk_judgments.jsonl are indexed when present.
# Example override: ALITIGATOR_RAG_ADDITIONAL_SOURCE_PATHS=data/processed/cbosa_nsa_fsk_judgments.jsonl
ALITIGATOR_RAG_ADDITIONAL_SOURCE_PATHS=
ALITIGATOR_RAG_DB_PATH=
ALITIGATOR_RAG_BACKEND=sqlite
ALITIGATOR_RAG_MYSQL_HOST=
ALITIGATOR_RAG_MYSQL_PORT=3306
ALITIGATOR_RAG_MYSQL_DATABASE=
ALITIGATOR_RAG_MYSQL_USER=
ALITIGATOR_RAG_MYSQL_PASSWORD=
ALITIGATOR_RAG_MYSQL_DOCUMENTS_TABLE=rag_documents
ALITIGATOR_RAG_MYSQL_CHUNKS_TABLE=rag_chunks
ALITIGATOR_RAG_MYSQL_SSL_DISABLED=false
ALITIGATOR_RAG_CHUNK_TARGET_CHARS=1400
ALITIGATOR_RAG_CHUNK_OVERLAP_CHARS=220
ALITIGATOR_RAG_TOP_K=6
ALITIGATOR_RAG_MAX_CONTEXT_CHARS=9000
ALITIGATOR_RAG_DOCUMENT_CONTEXT_ENABLED=true
ALITIGATOR_RAG_DOCUMENT_CONTEXT_DOCUMENTS=6
ALITIGATOR_RAG_DOCUMENT_CONTEXT_MAX_CHARS=120000
ALITIGATOR_RAG_SUPABASE_BATCH_SIZE=200
ALITIGATOR_RAG_SUPABASE_CHUNK_BATCH_SIZE=500
ALITIGATOR_RAG_SUPABASE_TIMEOUT_SECONDS=60
ALITIGATOR_RAG_SUPABASE_MAX_RETRIES=4
ALITIGATOR_RAG_SUPABASE_STATE_PATH=
ALITIGATOR_RAG_MAX_CHUNKS_PER_DOCUMENT=2
ALITIGATOR_RAG_EMBEDDING_DIMENSIONS=256
ALITIGATOR_RAG_HYBRID_LEXICAL_WEIGHT=0.65
ALITIGATOR_RAG_HYBRID_SEMANTIC_WEIGHT=0.35
ALITIGATOR_RAG_CANDIDATE_POOL_LIMIT=120
ALITIGATOR_RAG_LEGAL_MATCH_WEIGHT=0.02
ALITIGATOR_RAG_CROSS_ENCODER_ENABLED=true
ALITIGATOR_RAG_CROSS_ENCODER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
ALITIGATOR_RAG_CROSS_ENCODER_CACHE=
ALITIGATOR_RAG_CROSS_ENCODER_CANDIDATE_LIMIT=12
ALITIGATOR_RAG_CROSS_ENCODER_WEIGHT=0.70
ALITIGATOR_RAG_CROSS_ENCODER_DEVICE=cpu
ALITIGATOR_RAG_FACTS_CHANNEL_ENABLED=false
ALITIGATOR_RAG_DOMAIN_FILTER_ENABLED=false
LEGAL_RETRIEVAL_MODE=baseline
ENABLE_LEGAL_CLARIFIER=false
ANTHROPIC_CLARIFIER_MODEL=claude-haiku-4-5-20251001
AUTHORITY_RERANKER_VERSION=v1
AUTHORITY_CARD_SCHEMA_VERSION=v1
AUTHORITY_CARD_CACHE_ENABLED=true
HYBRID_RAG_PRIMARY_LIMIT_PER_ISSUE=6
HYBRID_RAG_AUTHORITY_CANDIDATE_LIMIT=10
HYBRID_RAG_SUPPORTING_LIMIT=4
HYBRID_RAG_CONTRARY_LIMIT=2
HYBRID_RAG_HISTORICAL_LIMIT=1
HYBRID_RAG_MIN_AUTHORITY_SCORE=0.38
HYBRID_RAG_ARTIFACT_ROOT=artifacts/hybrid_rag_experiment
HYBRID_RAG_FAST_SQL_PRIMARY=false
HYBRID_RAG_FAST_SQL_AUTHORITY=false
ALITIGATOR_RAG_USE_SUPABASE=false
ALITIGATOR_RAG_SUPABASE_SYNC=false
ALITIGATOR_RAG_SUPABASE_SCHEMA=public
ALITIGATOR_RAG_SUPABASE_DOCUMENTS_TABLE=eureka_interpretations
ALITIGATOR_RAG_SUPABASE_CHUNKS_TABLE=eureka_chunks
ALITIGATOR_RAG_SUPABASE_SEARCH_FUNCTION=search_eureka_chunks
